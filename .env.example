# ──────────────────────────────────────────────
# SarathiAgentInspect — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# ── Framework Environment ──
SARATHI_ENV=local                          # local | ci | production
SARATHI_DEBUG=true                         # Enable debug mode
SARATHI_LOG_LEVEL=DEBUG                    # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── LLM Provider: Ollama ──
OLLAMA_BASE_URL=http://localhost:11434     # Ollama API base URL
OLLAMA_MODEL=gemma4:31b-cloud             # Default Ollama model
OLLAMA_TIMEOUT=120                         # Request timeout in seconds

# ── LLM Provider: OpenAI ──
OPENAI_API_KEY=                            # OpenAI API key
OPENAI_MODEL=gpt-4o                        # Default OpenAI model
OPENAI_TIMEOUT=60                          # Request timeout in seconds

# ── LLM Provider: Anthropic ──
ANTHROPIC_API_KEY=                         # Anthropic API key
ANTHROPIC_MODEL=claude-sonnet-4-20250514          # Default Anthropic model

# ── LLM Provider: Google Gemini ──
GOOGLE_API_KEY=                            # Google API key
GEMINI_MODEL=gemini-2.5-pro               # Default Gemini model

# ── LLM Provider: Azure OpenAI ──
AZURE_OPENAI_API_KEY=                      # Azure OpenAI API key
AZURE_OPENAI_ENDPOINT=                     # Azure OpenAI endpoint URL
AZURE_OPENAI_DEPLOYMENT=                   # Azure deployment name
AZURE_OPENAI_API_VERSION=2024-02-01        # Azure API version

# ── Judge Model Configuration ──
SARATHI_JUDGE_PROVIDER=ollama              # Provider for judge model
SARATHI_JUDGE_MODEL=gemma4:31b-cloud       # Judge model name

# ── Langfuse (Observability) ──
LANGFUSE_PUBLIC_KEY=                       # Langfuse public key
LANGFUSE_SECRET_KEY=                       # Langfuse secret key
LANGFUSE_BASE_URL=http://localhost:3000    # Self-hosted Langfuse URL

# ── Evaluation Defaults ──
SARATHI_DEFAULT_THRESHOLD=0.7             # Default pass/fail threshold
SARATHI_MAX_WORKERS=4                      # Max parallel evaluation workers
SARATHI_RETRY_MAX_ATTEMPTS=3              # Max retry attempts for LLM calls
SARATHI_RETRY_BACKOFF_MULTIPLIER=2.0      # Exponential backoff multiplier
